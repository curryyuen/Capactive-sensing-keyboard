/*
  TFT_eSPI Test for ESP32-C3 + 80x160 IPS Display
  - Fills screen with colors
  - Draws text, rectangle, circle
  - Works with ST7735 or ST7789
*/

#include <TFT_eSPI.h>

TFT_eSPI tft = TFT_eSPI();

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("TFT Test Starting...");

  tft.init();
  tft.setRotation(1);   // Landscape (160x80)

  // Fill screen with black
  tft.fillScreen(TFT_BLACK);
  delay(500);

  // Test 1: Fill with red
  tft.fillScreen(TFT_RED);
  delay(1000);

  // Test 2: Fill with green
  tft.fillScreen(TFT_GREEN);
  delay(1000);

  // Test 3: Fill with blue
  tft.fillScreen(TFT_BLUE);
  delay(1000);

  // Back to black and draw white text
  tft.fillScreen(TFT_BLACK);
  tft.setTextColor(TFT_WHITE, TFT_BLACK);
  tft.setTextSize(1);
  tft.setCursor(10, 10);
  tft.println("Hello ESP32-C3!");
  tft.setCursor(10, 25);
  tft.println("80x160 IPS Test");
  delay(2000);

  // Draw a rectangle outline
  tft.drawRect(10, 40, 60, 30, TFT_YELLOW);
  // Draw a filled circle
  tft.fillCircle(130, 40, 15, TFT_CYAN);

  // Draw a line
  tft.drawLine(0, 70, 160, 70, TFT_MAGENTA);
}

void loop() {
  // Nothing here – just show the static screen
}
